{
  "name": "judas-viz",
  "version": "0.1.0",
  "private": true,
  "description": "Judas Arene - visualiseur 3D de matchs IA vs IA",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "dev:web": "vite",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.164.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "vite": "^5.4.21",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "dev.judas.viz",
    "productName": "Judas Arene",
    "files": [
      "dist/**",
      "electron/**"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
